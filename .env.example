# --- REQUIRED ---
STRIPE_SECRET_KEY=sk_live_[YOUR_NEW_KEY_HERE]

# Google Gemini API for Image Generation (Nano Banana)
GOOGLE_GEMINI_API_KEY=AIza[YOUR_GOOGLE_API_KEY_HERE]

# Vercel Blob Storage
BLOB_READ_WRITE_TOKEN=vercel_blob_xxx

# Your domain
CLIENT_URL=https://aiprint.ai

# Port for local development
PORT=3000

# --- WEBHOOKS ---
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- AUTHENTICATION & DATABASE (Required for credit system) ---
# JWT Secret for authentication tokens (generate a random string)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Vercel Postgres (automatically set by Vercel when you add Postgres storage)
# These will be auto-populated when you add Vercel Postgres to your project
POSTGRES_URL=postgres://...
POSTGRES_PRISMA_URL=postgres://...
POSTGRES_URL_NON_POOLING=postgres://...
POSTGRES_USER=default
POSTGRES_HOST=...
POSTGRES_PASSWORD=...
POSTGRES_DATABASE=...
