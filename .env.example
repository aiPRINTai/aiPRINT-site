# aiPRINT — env var template
#
# Copy to .env.local for local dev (never commit .env.local).
# In production, set each of these in Vercel → Project → Settings → Environment Variables.
#
# NEVER put real values in this file. If you must change defaults, change them in Vercel
# and in your local .env.local — this file is a template only.

# ── REQUIRED: Stripe ─────────────────────────────────────────────────────
# Secret key from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_[YOUR_KEY_HERE]
# Webhook signing secret — from the webhook endpoint settings page
STRIPE_WEBHOOK_SECRET=whsec_[YOUR_SIGNING_SECRET_HERE]

# ── REQUIRED: Google Gemini (image generation) ───────────────────────────
# https://aistudio.google.com/apikey
GOOGLE_GEMINI_API_KEY=AIza[YOUR_GOOGLE_API_KEY_HERE]

# ── REQUIRED: Vercel Blob (generated-image storage) ──────────────────────
# Auto-set by Vercel when Blob storage is attached. For local dev, copy from
# Vercel → Storage → Blob → .env.local tab.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_[YOUR_TOKEN_HERE]

# ── REQUIRED: Resend (transactional email) ───────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_[YOUR_RESEND_KEY_HERE]
# "From" address shown to recipients. Must be a verified sender domain in Resend.
EMAIL_FROM=aiPRINT <orders@aiprint.ai>
# Where contact-form messages and internal notifications land.
FULFILLMENT_TO=info@aiprint.ai

# ── REQUIRED: Auth (JWT) ─────────────────────────────────────────────────
# Sign user JWTs. Generate with: openssl rand -base64 48
# Must be 32+ chars. App refuses to start / sign tokens with a placeholder value.
JWT_SECRET=[GENERATE_WITH_openssl_rand_base64_48]

# ── REQUIRED: Admin dashboard password ───────────────────────────────────
# Bearer token for /admin/* API routes. Long random string — NOT a memorable word.
ADMIN_PASSWORD=[GENERATE_WITH_openssl_rand_base64_32]

# ── REQUIRED: Postgres (Neon or Vercel Postgres) ─────────────────────────
# Auto-set by Vercel when a Postgres integration is attached. For local dev,
# copy from Vercel → Storage → [your-db] → .env.local tab.
POSTGRES_URL=postgres://...
POSTGRES_PRISMA_URL=postgres://...
POSTGRES_URL_NON_POOLING=postgres://...
POSTGRES_USER=default
POSTGRES_HOST=...
POSTGRES_PASSWORD=...
POSTGRES_DATABASE=...

# ── Site config ──────────────────────────────────────────────────────────
# Public origin used for Stripe success/cancel URLs, password-reset links, etc.
CLIENT_URL=https://aiprint.ai

# Local-dev port (Vercel ignores this in production)
PORT=3000

# ── Optional ─────────────────────────────────────────────────────────────
# Set to any truthy value to enable verbose server logs.
# DEBUG_LOGS=1
