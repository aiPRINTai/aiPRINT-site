# OS / editor
.DS_Store
Thumbs.db

# Node / tooling (future-proofing for serverless routes)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Env & local config — NEVER commit anything that may hold secrets.
# Whitelist only the example template; block everything else.
.env
.env.*
.env.*.local
.env.local
.env.development
.env.development.local
.env.production
.env.production.local
.env.staging
.env.staging.local
.env.test
.env.test.local
.envrc
.direnv/
# Allow template files committed for onboarding
!.env.example
!.env.sample
!.env.template

# Vercel / deploy state
.vercel

# Credential dumps and auth artifacts
*.pem
*.key
*.pfx
*.p12
id_rsa
id_ed25519
*.keystore
# Editor-saved secret files
secrets.*
credentials.*
service-account*.json
gcp-*.json
aws-credentials*

# Generated doc previews — rebuild with `npm run docs`
docs-rendered/

# Local Claude Code config (per-machine)
.claude/

# Source imagery / working docs (kept out of the repo, stored elsewhere)
AiPrint Imagery/
aiPRINT-Lightroom-Shot-List.xlsx
competitor-analysis.csv
positioning-summary.md

# Local planning scratchpads (private — would be served publicly if committed
# to the repo root since /index.html siblings are treated as static routes).
your-todo.html
AiPrint-Icon.png
